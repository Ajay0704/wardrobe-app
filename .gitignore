# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# netlify
.netlify

# vercel
.vercel

# supabase CLI local temp/state
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor / Xcode (keep ios/App source; ignore build artifacts)
# Note: ios/App/App/public + capacitor.config.json ARE tracked so Xcode Cloud
# has the bundle resources without regenerating them (see ci_post_clone.sh).
ios/App/Pods
ios/App/Podfile.lock
ios/DerivedData
*.xcuserstate
xcuserdata/
.capacitor


# obsidian (local UI state — vault config and notes are tracked)
docs/.obsidian/workspace.json
docs/.obsidian/workspace-mobile.json
docs/.obsidian/trash/
docs/.trash/

# cursor mcp secrets (use .cursor/mcp.json.example as template)
.cursor/mcp.json

# obsidian plugin secrets (API key + cert — install plugin per vault)
docs/.obsidian/plugins/obsidian-local-rest-api/data.json
docs/.obsidian/community-plugins.json
