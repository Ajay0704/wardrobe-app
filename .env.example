# Supabase (optional — app works offline with localStorage alone)
# Create a project at https://supabase.com, run supabase/schema.sql, then fill these in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Obsidian Local REST API (for Cursor MCP — see docs/Obsidian setup.md)
OBSIDIAN_API_KEY=

# Set on Netlify: Site settings → Environment variables
