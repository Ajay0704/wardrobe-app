# Supabase (optional — app works offline with localStorage alone)
# Create a project at https://supabase.com, run supabase/schema.sql, then fill these in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server-only (push subscribe + cron). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (AI auto-tag + current try-on fallback)
GEMINI_API_KEY=

# FASHN virtual try-on (AJA-21) — identity-preserving VTON; blocked on budget
# https://docs.fashn.ai/ · replaces Gemini for /api/tryon when ready
FASHN_API_KEY=

# Visual search — closet photo → product link (AJA-79)
# Primary: https://serpapi.com (free ~250 searches/mo) → Google Lens
SERPAPI_API_KEY=
# Optional backup: https://www.searchapi.io → Yandex reverse image (~100 free)
SEARCHAPI_API_KEY=

# Explore feed ingest (/api/cron/ingest-feed) — eBay Browse + Partner Network
# https://developer.ebay.com → application keys + optional campaign id
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_CAMPAIGN_ID=

# Skimlinks Product API (AJA-93) — publisher ID 306112 once approved
SKIMLINKS_API_KEY=
SKIMLINKS_API_SECRET=

# Web Push (Phase 1.3) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Vercel Cron auth (Dashboard → Settings → Environment Variables)
CRON_SECRET=

# Support / Settings (AJA-55, AJA-56)
# Public site URL used by Share the app
NEXT_PUBLIC_APP_URL=https://wardrobe-app-lilac-two.vercel.app
# Apple App Store numeric id — enables Rate the app (write-review URL)
NEXT_PUBLIC_IOS_APP_ID=
NEXT_PUBLIC_SUPPORT_EMAIL=tajay0704@gmail.com

# Obsidian Local REST API (for Cursor MCP — see docs/Obsidian setup.md)
OBSIDIAN_API_KEY=

# Purchase import — email forward (AJA-114). Postmark inbound webhook.
# Basic-auth creds set on the Postmark inbound webhook URL
#   https://<user>:<pass>@<app>/api/import/email
INBOUND_WEBHOOK_USER=
INBOUND_WEBHOOK_PASS=
# The Postmark inbound address hash (public) — the part before "@inbound.postmarkapp.com".
# Per-user address = <hash>+<inbox_token>@inbound.postmarkapp.com
NEXT_PUBLIC_POSTMARK_INBOUND_HASH=

# Set on Vercel: Project → Settings → Environment Variables
