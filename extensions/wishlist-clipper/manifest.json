{
  "manifest_version": 3,
  "name": "Wardrobe Wishlist Clipper",
  "version": "1.1.1",
  "description": "One-gesture save of clothing product pages to your Wardrobe wishlist.",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting"],
  "host_permissions": [
    "https://wardrobe-app-lilac-two.vercel.app/*",
    "http://localhost:3000/*",
    "http://*/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://wardrobe-app-lilac-two.vercel.app/*",
      "http://localhost:3000/*"
    ]
  },
  "action": {
    "default_title": "Save to Wardrobe wishlist (⌥⇧W)"
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-to-wishlist": {
      "suggested_key": {
        "default": "Alt+Shift+W",
        "mac": "Alt+Shift+W"
      },
      "description": "Save current page to Wardrobe wishlist"
    },
    "open-clipper-settings": {
      "description": "Open Wardrobe clipper settings"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://wardrobe-app-lilac-two.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
